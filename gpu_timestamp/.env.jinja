# AWS Configuration
AWS_REGION={{ aws.region }}
LOCAL_DEV={{ local_dev }}

# S3 Buckets
AUDIO_BUCKET={{ s3.audio_bucket }}
TEXT_BUCKET={{ s3.transcription_fixes_bucket }}
OUTPUT_BUCKET={{ s3.output_bucket }}

# SQS Queues
SQS_QUEUE_URL={{ sqs.fix_transcribes_queue_url }}
SQS_FINAL_QUEUE_URL={{ sqs.final_queue_url }}

# stable-whisper Model Configuration
WHISPER_MODEL={{ stable_whisper.model }}
DEVICE={{ stable_whisper.device }}
LANGUAGE={{ stable_whisper.language }}
TOKEN_STEP={{ stable_whisper.token_step }}
ROLLING_AVG_TARGET={{ stable_whisper.rolling_avg_target }}

# DTW Alignment Parameters
DTW_BAND_WIDTH={{ dtw.band_width }}
DTW_STEP_PATTERN={{ dtw.step_pattern }}
DTW_MATCH_THRESHOLD={{ dtw.match_threshold }}
DTW_HIGH_DIST_THRESHOLD={{ dtw.high_dist_threshold }}
DTW_LOW_SCORE_THRESHOLD={{ dtw.low_score_threshold }}
DTW_JUMP_THRESHOLD={{ dtw.jump_threshold }}
DTW_DROP_THRESHOLD={{ dtw.drop_threshold }}
DTW_MA_WINDOW={{ dtw.ma_window }}
